# ============================================================
# EDUPLAY PLATFORM — ENVIRONMENT VARIABLES
# Copia questo file in .env.local e compila i valori reali.
# MAI committare il file .env.local su GitHub!
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Trovalo su: supabase.com > Progetto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── NEXT.JS ───────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-con-openssl-rand-base64-32

# ── STRIPE ────────────────────────────────────────────────────
# Trovalo su: dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── RESEND (Email) ────────────────────────────────────────────
# Trovalo su: resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@eduplay.io

# ── ONESIGNAL (Push Notifications) ────────────────────────────
# Trovalo su: onesignal.com > Settings > Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_API_KEY=...

# ── ANTHROPIC (Course Creator AI) ────────────────────────────
# Trovalo su: console.anthropic.com/account/keys
# Usato per: generazione struttura corso, contenuto lezioni, quiz, miglioramento testo
ANTHROPIC_API_KEY=sk-ant-...

# ── OLLAMA (AI Tutor - self-hosted) ───────────────────────────
# Avvia Ollama localmente: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── N8N (Automazioni) ─────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=...

# ── YOUTUBE (Video hosting) ───────────────────────────────────
YOUTUBE_API_KEY=AIza...

# ── APP CONFIG ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EduPlay
